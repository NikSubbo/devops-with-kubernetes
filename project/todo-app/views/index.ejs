<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link href="/css/style.css" rel="stylesheet" type="text/css" />
    <title>ToDo App</title>
  </head>
  <body>
    <div class="container">
      <h1>Todo App</h1>

      <img src="<%= imageSrc %>" alt="Todo" />

      <form class="form" action="http://todo-backend-svc:2346/todos" method="POST">
        <input
          type="text"
          name="todo"
          placeholder="Enter a new todo (max 140 characters)"
          maxlength="140"
        />
        <button type="submit">Send</button>
      </form>

      <h2>Todos</h2>

      <% if (todos.length === 0) { %>
        <p>No todos yet.</p>
      <% } else { %>
        <ul>
          <% todos.forEach(todo => { %>
            <li class="todo"><%= todo %></li>
          <% }) %>
        </ul>
      <% } %>
    </div>
  </body>
</html>
